# ── GT06 TCP Server ─────────────────────────────────────────────────────────
GT06_TCP_ADDR=:7019
GT06_HTTP_ADDR=:9091

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_GT06_DB=1
REDIS_POOL_SIZE=100

# ── Stream ───────────────────────────────────────────────────────────────────
STREAM_KEY=gt06:telemetry
STREAM_MAX_LEN=100000

# ── Protocol timing ──────────────────────────────────────────────────────────
AUTH_TIMEOUT=30s
HEARTBEAT_TIMEOUT=3m
WRITE_TIMEOUT=10s

# ── Database (disabled by default; set DB_HOST to enable) ────────────────────
DB_ENABLED=false
DB_HOST=
DB_PORT=3306
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_DATABASE=laravel
DB_DEVICE_TYPE_ID=2

# Configurable column names — override to match your schema without migration
DB_DEVICES_TABLE=devices
DB_IMEI_COLUMN=imei
DB_APPROVED_COLUMN=is_approved
DB_STATUS_COLUMN=status
DB_TYPE_ID_COLUMN=device_type_id
DB_NAME_COLUMN=name
DB_NOTES_COLUMN=notes
DB_CREATED_AT_COLUMN=created_at
DB_UPDATED_AT_COLUMN=updated_at

# ── Runtime ──────────────────────────────────────────────────────────────────
APP_DEBUG=false
SERVER_ID=
